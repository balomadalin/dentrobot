# ===== Server =====
PORT=3000

# ===== PostgreSQL (Railway o setează automat dacă adaugi plugin-ul Postgres) =====
DATABASE_URL=postgresql://user:pass@host:5432/dentrobot
# Setează "false" doar pentru development local fără SSL
DATABASE_SSL=true

# ===== Claude API =====
ANTHROPIC_API_KEY=sk-ant-xxxxx
CLAUDE_MODEL=claude-sonnet-4-5

# ===== Meta WhatsApp Cloud API =====
# Din Meta for Developers > App > WhatsApp > API Setup
WHATSAPP_TOKEN=EAAxxxxx
WHATSAPP_PHONE_NUMBER_ID=123456789012345
# Un string secret ales de tine, același pe care îl introduci la configurarea webhook-ului în Meta
WHATSAPP_VERIFY_TOKEN=dentrobot-verify-2026
META_GRAPH_VERSION=v21.0

# ===== Google Calendar (opțional - fără ele merge doar cu PostgreSQL) =====
# Conținutul JSON al Service Account-ului, pe o singură linie
GOOGLE_SERVICE_ACCOUNT_JSON=
# ID-ul calendarului partajat cu service account-ul (drept "Make changes to events")
GOOGLE_CALENDAR_ID=

# ===== Date cabinet (opțional - suprascriu valorile din src/clinic.ts) =====
CLINIC_NAME=Cabinet Stomatologic DemoDent
CLINIC_ADDRESS=Str. Exemplu nr. 10, Râmnicu Vâlcea
CLINIC_PHONE=+40 700 000 000
CLINIC_DOCTORS=Dr. Maria Popescu
CLINIC_TIMEZONE=Europe/Bucharest
